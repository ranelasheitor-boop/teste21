<script>
// CURSOR
const cursor = document.getElementById('cursor');
const follower = document.getElementById('cursorFollower');
let mx = 0, my = 0, fx = 0, fy = 0;
document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  cursor.style.left = mx + 'px';
  cursor.style.top = my + 'px';
});
(function animFollower() {
  fx += (mx - fx) * 0.12;
  fy += (my - fy) * 0.12;
  follower.style.left = fx + 'px';
  follower.style.top = fy + 'px';
  requestAnimationFrame(animFollower);
})();

// REVEAL ON SCROLL
const observer = new IntersectionObserver((entries) => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) setTimeout(() => e.target.classList.add('visible'), i * 80);
  });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// COUNTER
function animateCounter(el, target, duration) {
  let start = 0;
  const step = target / (duration / 16);
  const t = setInterval(() => {
    start += step;
    if (start >= target) { el.textContent = target + '+'; clearInterval(t); }
    else { el.textContent = Math.floor(start); }
  }, 16);
}
const counterObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      animateCounter(document.getElementById('years-counter'), 7, 1200);
      counterObs.disconnect();
    }
  });
}, { threshold: 0.5 });
const counterEl = document.getElementById('years-counter');
if (counterEl) counterObs.observe(counterEl);

// GALLERY FILTER
function filterGallery(cat, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.gallery-item').forEach(item => {
    const match = cat === 'todos' || item.dataset.cat === cat;
    item.style.opacity = match ? '1' : '0.2';
    item.style.pointerEvents = match ? 'all' : 'none';
  });
}

// LIGHTBOX
function openLightbox(title) {
  document.getElementById('lightbox-content').textContent = title;
  document.getElementById('lightbox').classList.add('open');
}
function closeLightbox() {
  document.getElementById('lightbox').classList.remove('open');
}
document.getElementById('lightbox').addEventListener('click', e => {
  if (e.target === e.currentTarget) closeLightbox();
});

// CHECK TOGGLE
function toggleCheck(el) {
  el.classList.toggle('selected');
}

// FORM SUBMIT
function submitForm(e) {
  e.preventDefault();
  const notif = document.getElementById('notification');
  notif.classList.add('show');
  setTimeout(() => notif.classList.remove('show'), 3500);
  e.target.reset();
  document.querySelectorAll('.check-item').forEach(el => el.classList.remove('selected'));
}
</script>
